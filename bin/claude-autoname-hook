#!/usr/bin/env python3
"""Claude Code Stop hook: set tmux window title to working directory basename."""

import json
import os
import subprocess
import sys
from datetime import datetime
from pathlib import Path


def log_window_action(action):
    """Log window naming operations to ~/.claude/logs/window-naming.log"""
    try:
        logfile = Path.home() / '.claude' / 'logs' / 'window-naming.log'
        logfile.parent.mkdir(parents=True, exist_ok=True)

        timestamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
        tmux_pane = os.environ.get('TMUX_PANE', 'unset')

        try:
            result = subprocess.run(
                ['tmux', 'display-message', '-p', '#{window_id}:#{window_name}'],
                capture_output=True, text=True, timeout=1
            )
            current_window = result.stdout.strip() if result.returncode == 0 else 'unknown'
        except Exception:
            current_window = 'unknown'

        with open(logfile, 'a') as f:
            f.write(f'[{timestamp}] [stop] TMUX_PANE={tmux_pane} current={current_window} action={action}\n')
    except Exception:
        pass  # Silent failure - logging should never break the hook


def get_cwd(transcript_path):
    try:
        with open(transcript_path) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    obj = json.loads(line)
                    cwd = obj.get('cwd')
                    if cwd:
                        return cwd
                except json.JSONDecodeError:
                    continue
    except Exception:
        pass
    return None


def set_title(name):
    if os.environ.get('TMUX'):
        try:
            pane = os.environ.get('TMUX_PANE', '')
            if pane:
                log_window_action(f"rename-window -t {pane} '{name}'")
                subprocess.run(['tmux', 'rename-window', '-t', pane, name], check=False)
                subprocess.run(['tmux', 'set-option', '-w', '-t', pane, '@claude_named', name], check=False)
            else:
                log_window_action(f"rename-window '{name}' (missing -t, will rename current window)")
                subprocess.run(['tmux', 'rename-window', name], check=False)
                subprocess.run(['tmux', 'set-option', '-w', '@claude_named', name], check=False)
        except Exception:
            pass
    else:
        try:
            with open('/dev/tty', 'w') as tty:
                tty.write(f'\033]0;{name}\007')
        except Exception:
            pass


def main():
    try:
        input_data = json.load(sys.stdin)
    except Exception:
        sys.exit(0)

    session_id = input_data.get('session_id', '')
    transcript_path = input_data.get('transcript_path', '')
    if not session_id or not transcript_path:
        sys.exit(0)

    if not Path(transcript_path).exists():
        sys.exit(0)

    names_dir = Path.home() / '.claude' / 'session-names'
    name_file = names_dir / session_id

    if name_file.exists():
        # Already titled — re-apply in case window was reset
        set_title(name_file.read_text().strip())
        sys.exit(0)

    cwd = get_cwd(transcript_path)
    if not cwd:
        sys.exit(0)

    # Skip internal tool sessions (e.g. claude-mem observer running in ~/.claude-mem/observer-sessions/).
    # Same guard as claude-session-start-hook — prevents bogus window names from propagating.
    home = str(Path.home())
    internal_prefixes = (home + '/.claude-mem/', home + '/.claude/')
    if any(cwd.startswith(p) for p in internal_prefixes):
        sys.exit(0)

    name = Path(cwd).name

    names_dir.mkdir(parents=True, exist_ok=True)
    name_file.write_text(name)
    set_title(name)


if __name__ == '__main__':
    main()
