#!/bin/bash
# Claude Code notification hook
# Triggers tmux bell and desktop notification when Claude needs input

# Logging function
log_window_action() {
    local logfile="$HOME/.claude/logs/window-naming.log"
    local timestamp; timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    local current_window; current_window=$(tmux display-message -p '#{window_id}:#{window_name}' 2>/dev/null || echo "unknown")
    printf '[%s] [notification] TMUX_PANE=%s current=%s action=%s\n' \
        "$timestamp" "${TMUX_PANE:-unset}" "$current_window" "$1" >> "$logfile" 2>/dev/null || true
}

# Read stdin
input=$(cat)

# Debug: log the input (uncomment to debug)
# echo "$input" > /tmp/claude-notification-debug.log

# Set window indicator
if [ -n "$TMUX_PANE" ] && command -v jq >/dev/null 2>&1; then
    session_id=$(echo "$input" | jq -r '.session_id // empty' 2>/dev/null)
    name_file="$HOME/.claude/session-names/$session_id"
    if [ -n "$session_id" ] && [ -f "$name_file" ]; then
        base=$(cat "$name_file")
        log_window_action "rename-window -t $TMUX_PANE '!${base}' (add ! prefix)"
        tmux rename-window -t "$TMUX_PANE" "!${base}" 2>/dev/null
    fi
fi

# Mark window as needing input (cleared by PreToolUse / Stop)
if [ -n "$TMUX_PANE" ] && [ -n "$TMUX" ]; then
    log_window_action "set-option -w -t $TMUX_PANE @claude-state waiting"
    tmux set-option -w -t "$TMUX_PANE" @claude-state "waiting" 2>/dev/null || true
    tmux refresh-client -S 2>/dev/null || true
fi

# Trigger tmux bell
if [ -n "$TMUX_PANE" ]; then
    # Print bell character to stderr (goes to the pane)
    printf '\a' >&2

    # Also write directly to the tty to ensure bell is visible
    tty=$(tmux display-message -pt "$TMUX_PANE" '#{pane_tty}' 2>/dev/null)
    if [ -n "$tty" ]; then
        printf '\a' > "$tty" 2>/dev/null
    fi
fi

exit 0
