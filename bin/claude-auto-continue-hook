#!/usr/bin/env python3
"""Claude Code Stop hook — auto-continue when incomplete tasks remain."""

import json
import sys
from datetime import datetime
from pathlib import Path

LOG_FILE = Path.home() / ".claude" / "auto-continue.log"


def log(session_id: str, msg: str) -> None:
    ts = datetime.now().strftime("%Y-%m-%dT%H:%M:%S")
    with LOG_FILE.open("a") as f:
        f.write(f"{ts} [{session_id[:8]}] {msg}\n")


def get_incomplete_tasks(transcript_path: str) -> list[dict]:
    """Replay TaskCreate/TaskUpdate calls to build current task state."""
    tasks: dict[str, dict] = {}
    try:
        with open(transcript_path) as f:
            for line in f:
                try:
                    obj = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if obj.get("type") != "assistant":
                    continue
                for block in obj.get("message", {}).get("content", []):
                    if not isinstance(block, dict) or block.get("type") != "tool_use":
                        continue
                    name = block.get("name", "")
                    inp = block.get("input", {})
                    if name == "TaskCreate":
                        task_id = inp.get("taskId") or str(len(tasks) + 1)
                        tasks[task_id] = {
                            "id": task_id,
                            "subject": inp.get("subject", ""),
                            "status": "pending",
                        }
                    elif name == "TaskUpdate":
                        task_id = inp.get("taskId")
                        if task_id and task_id in tasks:
                            if "status" in inp:
                                tasks[task_id]["status"] = inp["status"]
    except Exception:
        pass

    return [t for t in tasks.values() if t["status"] in ("pending", "in_progress")]


def main():
    try:
        data = json.load(sys.stdin)
    except Exception:
        sys.exit(0)

    session_id = data.get("session_id", "unknown")

    # Skip if we already re-entered from a prior hook block (prevent runaway)
    if data.get("stop_hook_active"):
        log(session_id, "skip stop_hook_active=true")
        sys.exit(0)

    transcript_path = data.get("transcript_path", "")
    if not transcript_path or not Path(transcript_path).exists():
        log(session_id, "skip no_transcript")
        sys.exit(0)

    incomplete = get_incomplete_tasks(transcript_path)

    if incomplete:
        names = ", ".join(t["subject"][:60] for t in incomplete)
        log(session_id, f"continue incomplete={len(incomplete)} tasks=[{names}]")
        reason = (
            f"{len(incomplete)} task(s) still incomplete: {names}. "
            "Continue working autonomously. Do not ask the user questions or "
            "pause for confirmation — make decisions and proceed."
        )
    else:
        log(session_id, "continue tasks=0 next-step-check")
        reason = (
            "All tasks complete. Assess whether there are obvious next steps "
            "with no blockers — if so, continue autonomously. "
            "If you are genuinely done or blocked, stop and summarize what was accomplished."
        )

    print(json.dumps({
        "decision": "block",
        "reason": reason,
        "hookSpecificOutput": {"stop_hook_active": True},
    }, ensure_ascii=False))
    sys.exit(2)


if __name__ == "__main__":
    main()
