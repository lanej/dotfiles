#!/usr/bin/env python3
"""Claude Code PreToolUse hook: color tmux window amber while a tool runs."""

import json
import os
import subprocess
import sys


def main():
    pane = os.environ.get('TMUX_PANE', '')
    if not pane or not os.environ.get('TMUX'):
        sys.exit(0)

    try:
        json.load(sys.stdin)  # consume stdin; fields not needed
    except Exception:
        sys.exit(0)

    try:
        subprocess.run(['tmux', 'set-option', '-w', '-t', pane, '@claude-state', 'tool'], check=False)
    except Exception:
        pass


if __name__ == '__main__':
    main()
