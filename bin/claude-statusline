#!/usr/bin/env bash
# Claude Code status line (starship-style)

set -euo pipefail

# Read JSON input and extract fields
input=$(cat)
cwd=$(echo "$input" | jq -r '.workspace.current_dir')
worktree_name=$(echo "$input" | jq -r '.worktree.name // empty')
model_id=$(echo "$input" | jq -r '.model.id')
model_name=$(echo "$input" | jq -r '.model.display_name')
total_input=$(echo "$input" | jq -r '.context_window.total_input_tokens // 0')
total_output=$(echo "$input" | jq -r '.context_window.total_output_tokens // 0')
vim_mode=$(echo "$input" | jq -r '.vim.mode // empty')
effort=$(echo "$input" | jq -r '.effort.level // empty')
thinking=$(echo "$input" | jq -r '.thinking.enabled // empty')

# Change to working directory for git operations
cd "$cwd" 2>/dev/null || true

# Nerd Font glyphs via UTF-8 hex — safe on bash 3.2 (no $'\uNNNN' support there)
ssh_sym=$(printf '\xef\xa0\x97')   # U+F817 nf-mdi-ssh
git_sym=$(printf '\xee\x82\xa0')   # U+E0A0 nf-pl-branch
wt_sym=$(printf '\xef\x84\xa6')    # U+F126 nf-fa-code_fork (worktree)
vim_sym=$(printf '\xee\x98\xab')   # U+E62B nf-dev-vim

# User and hostname
user=$(whoami)
host=$(hostname -s)

# Minimum unique prefix of $name among siblings in $parent_dir
_min_prefix() {
  local name="$1" parent="$2" len=1 prefix others
  while [ "$len" -lt "${#name}" ]; do
    prefix="${name:0:$len}"
    # awk avoids pipefail issues from grep exiting 1 on no-match
    # shellcheck disable=SC2012
    others=$(ls -1A "$parent" 2>/dev/null | awk -v p="$prefix" -v n="$name" 'substr($0,1,length(p))==p && $0!=n{c++} END{print c+0}')
    [ "$others" -eq 0 ] && break
    len=$((len + 1))
  done
  printf '%s' "${name:0:$len}"
}

# Fish-style unique-truncated absolute path (HOME → ~); all non-leaf components shortened
_fish_path() {
  local full_path="$1" result="" phys="$HOME" part short n i
  local display="${full_path/#$HOME/~}"
  local IFS_save="$IFS"
  IFS='/' read -ra _fp_parts <<< "$display"
  IFS="$IFS_save"
  n="${#_fp_parts[@]}"; i=0
  while [ "$i" -lt "$n" ]; do
    part="${_fp_parts[$i]}"
    if [ -z "$part" ]; then i=$((i+1)); continue; fi
    if [ "$part" = "~" ]; then result="~"; i=$((i+1)); continue; fi
    if [ "$i" -eq "$((n - 1))" ]; then
      result="${result}/${part}"
    else
      short=$(_min_prefix "$part" "$phys")
      result="${result}/${short}"
      phys="${phys}/${part}"
    fi
    i=$((i+1))
  done
  printf '%s' "$result"
}

# Fish-style truncation of a relative path anchored at $base_dir
_fish_path_rel() {
  local rel="$1" base="$2"
  local result="" phys part short n i
  phys="$base"
  local IFS_save="$IFS"
  IFS='/' read -ra _fpr_parts <<< "$rel"
  IFS="$IFS_save"
  n="${#_fpr_parts[@]}"; i=0
  while [ "$i" -lt "$n" ]; do
    part="${_fpr_parts[$i]}"
    if [ -z "$part" ]; then i=$((i+1)); continue; fi
    if [ "$i" -eq "$((n - 1))" ]; then
      result="${result:+${result}/}${part}"
    else
      short=$(_min_prefix "$part" "$phys")
      result="${result:+${result}/}${short}"
      phys="${phys}/${part}"
    fi
    i=$((i+1))
  done
  printf '%s' "$result"
}

# Directory: fish-style unique-truncated path; git worktrees show main repo path
in_worktree=false
wt_display_name=""
if git rev-parse --git-dir >/dev/null 2>&1; then
  git_root=$(git rev-parse --show-toplevel 2>/dev/null)
  git_cur_dir=$(git rev-parse --git-dir 2>/dev/null)
  git_common_dir=$(git rev-parse --git-common-dir 2>/dev/null)
  # Normalize to canonical absolute paths — git returns relative paths like ".git" or "../.git"
  git_cur_dir=$(cd "$git_cur_dir" 2>/dev/null && pwd || echo "$git_cur_dir")
  git_common_dir=$(cd "$git_common_dir" 2>/dev/null && pwd || echo "$git_common_dir")
  if [ "$git_cur_dir" != "$git_common_dir" ]; then
    in_worktree=true
    wt_display_name="${worktree_name:-$(basename "$git_cur_dir")}"
    dir=$(_fish_path "$(dirname "$git_common_dir")")
  else
    root_display=$(_fish_path "$git_root")
    if [ "$cwd" = "$git_root" ]; then
      dir="$root_display"
    else
      within="${cwd#"${git_root}"/}"
      dir="${root_display}:$(_fish_path_rel "$within" "$git_root")"
    fi
  fi
else
  dir=$(_fish_path "$cwd")
fi

# Build status line: user@host (SSH only) then directory
if [ -n "${SSH_CLIENT:-}" ] || [ -n "${SSH_TTY:-}" ]; then
  printf '\033[36m%s\033[33m@\033[32;1m%s %s\033[0m \033[34;1m%s\033[0m' "$user" "$host" "$ssh_sym" "$dir"
else
  printf '\033[34;1m%s\033[0m' "$dir"
fi

# Git information (if in repo)
if git rev-parse --git-dir >/dev/null 2>&1; then
  if [ "$in_worktree" = "true" ]; then
    # Worktree: replace branch indicator with worktree name in cyan
    printf ' \033[36m%s %s\033[0m' "$wt_sym" "$wt_display_name"
  else
    branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
    if [ -n "$branch" ]; then
      printf ' \033[34m%s %s\033[0m' "$git_sym" "$branch"

      # Ahead/behind tracking
      # shellcheck disable=SC1083
      upstream=$(git rev-parse --abbrev-ref @{upstream} 2>/dev/null || echo "")
      if [ -n "$upstream" ]; then
        # shellcheck disable=SC1083
        ahead=$(git rev-list --count @{upstream}..HEAD 2>/dev/null || echo "0")
        # shellcheck disable=SC1083
        behind=$(git rev-list --count HEAD..@{upstream} 2>/dev/null || echo "0")

        if [ "$ahead" -gt 0 ] && [ "$behind" -gt 0 ]; then
          printf ' \033[33m⇕⇡%s⇣%s\033[0m' "$ahead" "$behind"
        elif [ "$ahead" -gt 0 ]; then
          printf ' \033[33m⇡%s\033[0m' "$ahead"
        elif [ "$behind" -gt 0 ]; then
          printf ' \033[33m⇣%s\033[0m' "$behind"
        fi
      fi
    fi
  fi

  # Staged/modified/untracked (shown in both worktree and normal)
  staged=$(git diff --cached --name-only 2>/dev/null | wc -l | tr -d ' ')
  modified=$(git diff --name-only 2>/dev/null | wc -l | tr -d ' ')
  untracked=$(git ls-files --others --exclude-standard 2>/dev/null | wc -l | tr -d ' ')

  if [ "$staged" -gt 0 ] || [ "$modified" -gt 0 ] || [ "$untracked" -gt 0 ]; then
    printf ' '
    [ "$staged" -gt 0 ]    && printf '\033[32m+%s\033[0m' "$staged"
    [ "$modified" -gt 0 ]  && printf '\033[33m~%s\033[0m' "$modified"
    [ "$untracked" -gt 0 ] && printf '\033[31m?%s\033[0m' "$untracked"
  fi
fi

# Session cost estimate from cumulative token counts
if [ "$total_input" -gt 0 ] || [ "$total_output" -gt 0 ]; then
  # Pricing per million tokens (input/output) — approximate, Vertex may differ
  case "$model_id" in
    *opus*)  in_price="15"; out_price="75" ;;
    *haiku*) in_price="0.8"; out_price="4" ;;
    *)       in_price="3"; out_price="15" ;;  # sonnet default
  esac
  cost=$(awk "BEGIN { printf \"%.2f\", ($total_input * $in_price / 1000000 + $total_output * $out_price / 1000000) }")
  if awk "BEGIN { exit !($cost >= 2.00) }"; then
    printf ' \033[37m$%s\033[0m' "$cost"
  fi
fi

# Vim mode indicator
if [ -n "$vim_mode" ]; then
  case "$vim_mode" in
    "NORMAL") printf ' \033[33m%s\033[0m' "$vim_sym" ;;
    "INSERT") ;;
  esac
fi

# Model name
if [ -n "$model_name" ] && [ "$model_name" != "null" ]; then
  printf ' \033[90m%s\033[0m' "$model_name"
fi

# Mode indicators: thinking + effort
# U+F0EB nf-fa-lightbulb_o (thinking); U+2191/2193 arrows (effort)
lightbulb=$(printf '\xef\x83\xab')   # U+F0EB nf-fa-lightbulb_o
[ "$thinking" = "true" ] && printf ' \033[33m%s\033[0m' "$lightbulb"
case "$effort" in
  "low")          printf ' \033[90m↓\033[0m' ;;
  "high")         printf ' \033[32m↑\033[0m' ;;
  "xhigh"|"max")  printf ' \033[32;1m↑↑\033[0m' ;;
esac
