#!/usr/bin/env bash
# Post-save hook for tmux-resurrect.
# Caps history at KEEP non-degenerate snapshots, pruning the oldest.
# Note: resurrect already deduplicates identical saves (files_differ check in save.sh).
set -euo pipefail

RESURRECT_DIR="$HOME/.tmux/resurrect"
DEGENERATE_BYTES=100
KEEP=50

real=()
while IFS= read -r f; do
    size=$(wc -c < "$f")
    (( size >= DEGENERATE_BYTES )) && real+=("$f")
done < <(ls -1 "$RESURRECT_DIR"/tmux_resurrect_*.txt 2>/dev/null | sort -r)

if [[ ${#real[@]} -gt $KEEP ]]; then
    for f in "${real[@]:$KEEP}"; do
        rm -f "$f"
    done
fi
