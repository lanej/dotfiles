#!/usr/bin/env bash
# Trigger a tmux-resurrect restore. Invoke explicitly; not bound to a tmux key.
plugin_path=$(tmux show-environment -g TMUX_PLUGIN_MANAGER_PATH 2>/dev/null | cut -d= -f2)
plugin_path="${plugin_path:-$HOME/.config/tmux/plugins/}"
exec "${plugin_path}tmux-resurrect/scripts/restore.sh"
