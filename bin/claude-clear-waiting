#!/bin/bash
# Args passed from hook at fire time: window_id, window_name
# Both are expanded synchronously by tmux before run-shell launches.
window_id="$1"
window_name="$2"
tmux set-option -w -t "$window_id" @claude-state ""
tmux rename-window -t "$window_id" "${window_name#!}"
tmux refresh-client -S
