#!/usr/bin/env bash
# Cycle to the next interesting window in the current session (wraps around).
# Interesting: bell flag, ! prefix (Claude waiting), or @claude-state set.
# Excludes the current window. Popup session searches session 0.

LOG=/tmp/tmux-quickswitch-alert.log
log() { printf '[%s] %s\n' "$(date +%H:%M:%S)" "$*" >> "$LOG"; }

current_session=$(tmux display-message -p '#{session_name}')
current_idx=$(tmux display-message -p '#{window_index}')
[[ "$current_session" == "popup" ]] && search_flags="-t 0" || search_flags=""

log "--- invoked session=$current_session current_idx=$current_idx ---"

# Collect interesting windows: index|id, sorted by index ascending
# Interesting = bell OR ! prefix OR non-empty @claude-state
candidates=()
while IFS= read -r line; do
  candidates+=("$line")
done < <(
  tmux list-windows $search_flags \
    -F "#{window_index}|#{window_id}|#{window_bell_flag}|#{@claude-state}|#{window_name}" \
  | awk -F'|' -v cur="$current_idx" '{
      idx=$1; id=$2; bell=$3; claude=$4; name=$5;
      waiting=(substr(name,1,1)=="!") ? 1 : 0;
      if (idx!=cur && (bell=="1" || waiting || claude!="")) print idx "|" id
    }' \
  | sort -t'|' -k1,1 -n
)

log "candidates: ${candidates[*]}"

if [[ ${#candidates[@]} -eq 0 ]]; then
  log "no interesting windows"
  exit 0
fi

# Next = first candidate with index > current; wrap to first if none
win_id=""
for c in "${candidates[@]}"; do
  idx="${c%%|*}"
  if (( idx > current_idx )); then
    win_id="${c##*|}"
    break
  fi
done
[[ -z "$win_id" ]] && win_id="${candidates[0]##*|}"

log "selecting win_id=$win_id"

if [[ "$current_session" == "popup" ]]; then
  client=$(tmux display-message -p '#{client_name}')
  tmux switch-client -c "$client" -t 0
fi

tmux select-window -t "$win_id"

pane=$(tmux list-panes -t "$win_id" -F "#{pane_bell_flag}|#{pane_index}" \
  | sort -t'|' -k1,1 -rn -k2,2 -n \
  | head -1 \
  | cut -d'|' -f2)
[[ -n "$pane" ]] && tmux select-pane -t "${win_id}.${pane}"
log "done pane=$pane"
