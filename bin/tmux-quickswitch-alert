#!/usr/bin/env bash
# Jump to the most urgent window (bell > activity, then lowest index).
# Within the window, selects the pane with a bell flag if identifiable.

target=$(tmux list-windows -F "#{window_bell_flag}|#{window_activity_flag}|#{window_index}" \
  | sort -t'|' -k1,1 -rn -k2,2 -rn -k3,3 -n \
  | head -1)

[[ -z "$target" ]] && exit 0

bell=$(printf '%s' "$target" | cut -d'|' -f1)
activity=$(printf '%s' "$target" | cut -d'|' -f2)
win=$(printf '%s' "$target" | cut -d'|' -f3)

[[ "$bell" == "0" && "$activity" == "0" ]] && exit 0

tmux select-window -t ":$win"

# Select the pane with the bell flag; fall back to lowest-index pane
pane=$(tmux list-panes -t ":$win" -F "#{pane_bell_flag}|#{pane_index}" \
  | sort -t'|' -k1,1 -rn -k2,2 -n \
  | head -1 \
  | cut -d'|' -f2)

[[ -n "$pane" ]] && tmux select-pane -t ":$win.$pane"
