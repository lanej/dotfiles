#!/bin/bash

# Get the current pane ID and session name
PANE_ID=$(tmux display-message -p "#{pane_id}")
SESSION_NAME=$(tmux display-message -p "#{session_name}")

# Use fzf to select destination window and move the pane
DEST_WINDOW=$({ echo "new|New Window"; tmux list-windows -t "$SESSION_NAME" -F "#{window_index}|#{window_name} #{?window_active,[active],}"; } | \
fzf --height=100% --reverse \
    --header="Move pane to window" \
    --color=pointer:#d787d7,header:#d787d7,hl+:#ffafaf \
    --preview "echo {} | cut -d'|' -f1 | xargs -I {} tmux capture-pane -ep -t '$SESSION_NAME':{} -S -30 2>/dev/null || echo 'Preview unavailable'" \
    --preview-window=right:60% | \
cut -d'|' -f1 || true)

# Only move if a window was selected
if [ -n "$DEST_WINDOW" ]; then
    if [ "$DEST_WINDOW" = "new" ]; then
        NEW_WIN=$(tmux break-pane -s "$PANE_ID" -P -F "#{window_index}")
        tmux select-window -t "$SESSION_NAME:$NEW_WIN"
    else
        tmux move-pane -s "$PANE_ID" -t "$SESSION_NAME:$DEST_WINDOW"
    fi
fi

exit 0