#!/usr/bin/env bash
# Close ghostty surface with confirmation if tmux or SSH is active.
# Designed to be called via ghostty keybind: cmd+w=run:~/.local/bin/ghostty-close-tab

active=()

# Check for active tmux sessions
if tmux list-sessions &>/dev/null 2>&1; then
    active+=("tmux")
fi

# Check for active SSH connections (outbound)
if pgrep -u "$USER" -x ssh &>/dev/null; then
    active+=("SSH")
fi

if [[ ${#active[@]} -gt 0 ]]; then
    label=$(IFS=" and "; echo "${active[*]}")
    if osascript -e "button returned of (display dialog \"${label} session active. Close tab?\" buttons {\"Cancel\", \"Close\"} default button \"Cancel\" with icon caution)" 2>/dev/null | grep -q "Close"; then
        osascript -e 'tell application "Ghostty" to close front window'
    fi
else
    osascript -e 'tell application "Ghostty" to close front window'
fi
