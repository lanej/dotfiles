{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_USE_VERTEX": "1",
    "ANTHROPIC_VERTEX_PROJECT_ID": "easypost-platform"
  },
  "permissions": {
    "allow": [
      "Bash"
    ],
    "deny": [
      "Bash(rm:-rf /)",
      "Bash(rm:-rf:/ *)",
      "Bash(sudo:rm:*)",
      "Bash(sudo:dd:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(parted:*)",
      "Bash(wipefs:*)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": []
  },
  "model": "claude-sonnet-4-6[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.files/bin/claude-notification-hook"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.files/bin/claude-worktree-create-hook"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.files/bin/claude-worktree-remove-hook"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.files/bin/claude-auto-continue-hook"
          },
          {
            "type": "command",
            "command": "$HOME/.files/bin/claude-autoname-hook"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.files/bin/claude-statusline"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754065442220
  },
  "effortLevel": "high"
}
